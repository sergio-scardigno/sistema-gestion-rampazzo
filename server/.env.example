# Directorio donde se almacenan los archivos
RAMPAZZO_STORAGE_DIR=/opt/rampazzo/documentos

# API Key para autenticacion (CAMBIAR por una clave segura)
RAMPAZZO_API_KEY=CAMBIAR-POR-UNA-CLAVE-SEGURA

# Host y puerto del servidor
RAMPAZZO_HOST=0.0.0.0
RAMPAZZO_PORT=8443

# Tamano maximo de archivo en MB
RAMPAZZO_MAX_FILE_SIZE_MB=5

# Directorio de backups comprimidos (.tar.zst)
RAMPAZZO_BACKUP_DIR=/opt/rampazzo/backups

# Retencion de backups en semanas
RAMPAZZO_BACKUP_RETENTION_WEEKS=4
